# ─────────────────────────────────────────────────────────────
# EduTrack Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
#
# For LOCAL development: set these as system env vars, or use a .env plugin.
# For PRODUCTION (Railway): add these in Railway → Service → Variables tab.
#
# ⚠️  NEVER commit this file with real values to Git.

# ── Database (Neon PostgreSQL) ──────────────────────────────
# Get this from neon.tech → your project → Connection String
# MUST start with jdbc:postgresql:// (not plain postgresql://)
DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# ── JWT Security ─────────────────────────────────────────────
# Generate a random 64+ character string:  https://randomkeygen.com (use 504-bit WPA Key)
# ⚠️  REQUIRED — the app WILL NOT START without this variable set.
#     This is intentional (Bug Fix #9) to prevent use of weak defaults in production.
JWT_SECRET=REPLACE_WITH_64_PLUS_RANDOM_CHARS_HERE_DO_NOT_USE_THIS_VALUE

# ── Email (Brevo SMTP) ────────────────────────────────────────
# Sign up at brevo.com → SMTP & API → Generate SMTP key
BREVO_SMTP_USER=your_brevo_login@example.com
BREVO_SMTP_KEY=your_brevo_smtp_api_key

# ── School Config ─────────────────────────────────────────────
EMAIL_FROM=noreply@yourschool.edu
SCHOOL_NAME=Mahinda College

# ── QR Code Base URL ─────────────────────────────────────────
# Your deployed frontend URL — used to generate scannable QR links
# e.g.  https://edutrack.vercel.app
QR_BASE_URL=https://your-frontend.vercel.app
